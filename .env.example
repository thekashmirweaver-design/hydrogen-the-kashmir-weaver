# Hydrogen / Oxygen (required for production)
SESSION_SECRET=
PUBLIC_STOREFRONT_API_TOKEN=
PRIVATE_STOREFRONT_API_TOKEN=
PUBLIC_STORE_DOMAIN=
SHOPIFY_STOREFRONT_ID=

# Optional storefront behaviour
CONCIERGE_WEBHOOK_URL=
USE_STATIC_CATALOG=true

# Shopify Admin seed script only (scripts/seed-shopify-admin.ts)
SHOPIFY_ADMIN_ACCESS_TOKEN=
# Public URL where /assets/* images are reachable (your Oxygen URL or custom domain)
PUBLIC_STORE_URL=https://your-store.myshopify.com
