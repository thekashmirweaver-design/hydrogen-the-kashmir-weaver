# ── Fastest setup ─────────────────────────────────────────────────────────────
# npx shopify hydrogen link
# npx shopify hydrogen env pull
# Most Hydrogen/Oxygen vars below are filled automatically after link + pull.
# Generate SESSION_SECRET yourself: openssl rand -hex 32

# ── Required (Oxygen / local dev) ─────────────────────────────────────────────
SESSION_SECRET=
# Storefront API public token (from Headless channel / hydrogen env pull).
PUBLIC_STOREFRONT_API_TOKEN=
# Optional server-side private token. Leave unset to use PUBLIC token (recommended
# unless you have a distinct private token from hydrogen env pull).
# NEVER put an Admin shpat_ token here — Hydrogen sends Shopify-Storefront-Id and
# invalid private tokens cause 401 → static catalog fallback.
# PRIVATE_STOREFRONT_API_TOKEN=
PUBLIC_STORE_DOMAIN=
PUBLIC_STOREFRONT_ID=
PUBLIC_CHECKOUT_DOMAIN=

# ── Customer Account API (account login) ──────────────────────────────────────
# Pulled automatically by `npx shopify hydrogen env pull` after linking.
# Required on Oxygen for /account login; missing vars cause auth failures.
PUBLIC_CUSTOMER_ACCOUNT_API_CLIENT_ID=
PUBLIC_CUSTOMER_ACCOUNT_API_URL=
SHOP_ID=

# ── Optional storefront behaviour ─────────────────────────────────────────────
# Keep true until npm run seed:shopify completes, then remove or set false.
USE_STATIC_CATALOG=true
# HTTPS endpoint that receives concierge form POSTs (Zapier, Make, custom API).
CONCIERGE_WEBHOOK_URL=

# ── Seed script only (scripts/seed-shopify-admin.ts) ──────────────────────────
# Admin → Settings → Apps → Develop apps → Create app → Admin API token
SHOPIFY_ADMIN_ACCESS_TOKEN=
# Live Oxygen URL so product images load from /assets/* during seeding.
PUBLIC_STORE_URL=https://your-storefront.example.com
